generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                String    @id @default(cuid())
  waId              String    @unique
  displayName       String?
  name              String?
  phone             String
  email             String?
  businessName      String?
  businessType      String?
  monthlyBudget     String?
  budgetAmount      Float?
  businessAge       String?
  businessAgeMonths Int?
  qualified         Boolean?
  disqualified      Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  meetings          Meeting[]
}

model Meeting {
  id              String   @id @default(cuid())
  waId            String
  lead            Lead     @relation(fields: [waId], references: [waId])
  scheduledAt     DateTime
  slotId          String?
  calendarEventId String?
  attendeeName    String?
  attendeeEmail   String?
  attendeePhone   String?
  status          String   @default("SCHEDULED")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Sin FK a Lead — la conversación se crea desde el primer mensaje,
// antes de que el Lead exista en la DB
model Conversation {
  id        String    @id @default(cuid())
  waId      String
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([waId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String
  content        String       @db.Text
  createdAt      DateTime     @default(now())
}
