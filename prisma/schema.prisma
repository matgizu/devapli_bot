generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id                String    @id @default(cuid())
  waId              String    @unique
  displayName       String?
  name              String?
  phone             String
  email             String?
  businessName      String?
  businessType      String?
  monthlyBudget     String?
  budgetAmount      Float?
  businessAge       String?
  businessAgeMonths Int?
  qualified         Boolean?
  disqualified      Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  meetings          Meeting[]
}

model Meeting {
  id                   String    @id @default(cuid())
  waId                 String
  lead                 Lead      @relation(fields: [waId], references: [waId])

  scheduledAt          DateTime
  endsAt               DateTime  // scheduledAt + 30 min

  attendeeName         String?
  attendeeEmail        String?
  attendeePhone        String?

  // Estado: SCHEDULED | CONFIRMED | CANCELLED | COMPLETED | NO_SHOW
  status               String    @default("SCHEDULED")
  cancelReason         String?

  // Recordatorios
  reminder24hSentAt    DateTime?
  reminder2hSentAt     DateTime?

  // Confirmación del prospecto (respuesta al recordatorio 24h)
  confirmationResponse String?   // "YES" | "NO"
  confirmedAt          DateTime?

  // Link de videollamada (si aplica)
  meetingUrl           String?

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([scheduledAt])
  @@index([status])
}

// Sin FK a Lead — la conversación se crea desde el primer mensaje
model Conversation {
  id        String    @id @default(cuid())
  waId      String
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([waId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String       // "user" | "assistant"
  content        String       @db.Text
  createdAt      DateTime     @default(now())
}
