{
  "name": "bot-agencia",
  "version": "1.0.0",
  "description": "Bot de ventas WhatsApp para agencia de marketing con IA",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "sandbox": "ts-node src/sandbox.ts",
    "sandbox:real": "ts-node src/sandbox.ts --real-slots",
    "build": "prisma generate && tsc",
    "start": "prisma generate && prisma db push && node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "form-data": "^4.0.1",
    "node-fetch": "^2.7.0",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/node-fetch": "^2.6.12",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
