# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
META_APP_SECRET=abc123def456abc123def456abc12345
META_VERIFY_TOKEN=token_que_vos_definas

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxx

# ─── OpenAI Whisper (transcripción de audios) ────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxx

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Google Calendar ──────────────────────────────────────────────────────────
# 1. Ir a console.cloud.google.com → crear proyecto → habilitar "Google Calendar API"
# 2. IAM → Cuentas de servicio → crear cuenta → descargar JSON de credenciales
# 3. Compartir tu calendario de Google con el email de la cuenta de servicio (editor)
# 4. Copiar client_email y private_key del JSON descargado

GOOGLE_CLIENT_EMAIL=bot-agencia@tu-proyecto.iam.gserviceaccount.com
# Pegar la private key completa (incluyendo -----BEGIN/END PRIVATE KEY-----)
# En Railway pegar tal cual; el código reemplaza los \n automáticamente
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# ID del calendario: "primary" para el principal, o el email del calendario específico
GOOGLE_CALENDAR_ID=primary

TZ=America/Bogota

# ─── Agencia (datos de presentación) ─────────────────────────────────────────
AGENCY_NAME=Tu Agencia
AGENCY_BOT_NAME=Aria
OWNER_NAME=Nombre del Fundador

# ─── Imágenes de resultados (prueba social) ───────────────────────────────────
# Subí las imágenes a Cloudinary, S3, Imgur o cualquier hosting público
# Si no configurás ninguna, el bot funciona igual pero sin enviar imágenes
PROOF_IMAGE_1_URL=https://ejemplo.com/resultado-cliente-1.jpg
PROOF_IMAGE_1_CAPTION=Cliente sector salud — 4.2x ROAS en el tercer mes 📈
PROOF_IMAGE_2_URL=https://ejemplo.com/resultado-cliente-2.jpg
PROOF_IMAGE_2_CAPTION=E-commerce — 320% de facturación en 60 días 🚀
PROOF_IMAGE_3_URL=
PROOF_IMAGE_3_CAPTION=

# ─── Telegram (alertas opcionales) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Devapli — Demo de bot ────────────────────────────────────────────────────
DEVAPLI_DEMO_API_KEY=

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
