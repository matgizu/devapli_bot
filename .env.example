# ─── WhatsApp Cloud API ───────────────────────────────────────────────────────
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
META_APP_SECRET=abc123def456abc123def456abc12345
META_VERIFY_TOKEN=token_que_vos_definas

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxx

# ─── OpenAI Whisper (transcripción de audios) ────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxx

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Calendario (Cal.com) ─────────────────────────────────────────────────────
# Obtener en: https://app.cal.com/settings/developer/api-keys
CALCOM_API_KEY=cal_live_xxxxxxxxxxxxxxxxxx
# El ID del tipo de evento (ej: "sesion-estrategica-30min")
CALCOM_EVENT_TYPE_SLUG=sesion-estrategica
# Tu username en Cal.com
CALCOM_USERNAME=tu_usuario
# ID numérico del tipo de evento (lo ves en la URL cuando editas el evento)
CALCOM_EVENT_TYPE_ID=12345
# Zona horaria del negocio
TZ=America/Bogota

# ─── Agencia (datos de presentación) ─────────────────────────────────────────
AGENCY_NAME=Tu Agencia
AGENCY_BOT_NAME=Aria
OWNER_NAME=Nombre del Fundador

# ─── Imágenes de resultados (prueba social) ───────────────────────────────────
# Subí las imágenes a Cloudinary, S3, Imgur o cualquier hosting público
# Si no configurás ninguna, el bot funciona igual pero sin enviar imágenes
PROOF_IMAGE_1_URL=https://ejemplo.com/resultado-cliente-1.jpg
PROOF_IMAGE_1_CAPTION=Cliente sector salud — 4.2x ROAS en el tercer mes 📈
PROOF_IMAGE_2_URL=https://ejemplo.com/resultado-cliente-2.jpg
PROOF_IMAGE_2_CAPTION=E-commerce — 320% de facturación en 60 días 🚀
PROOF_IMAGE_3_URL=
PROOF_IMAGE_3_CAPTION=

# ─── Telegram (alertas opcionales) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
